# App Store Connect API credentials.
# Copy this file to .env and fill in real values.
# .env is gitignored; never commit real credentials.

# 10-character key ID from App Store Connect → Users and Access → Keys
ASC_KEY_ID=

# UUID issuer ID from App Store Connect → Users and Access → Keys
ASC_ISSUER_ID=

# Path to the .p8 private key file (relative to project root or absolute).
ASC_PRIVATE_KEY_PATH=AppStoreConnectAuthKey.p8

# Numeric app ID (optional; used by CLI helpers that operate on a single app).
ASC_APP_ID=

# JWT expiration in minutes. Apple enforces a 20-minute maximum; 19 is the safe default.
ASC_EXPIRATION_MINUTES=19
